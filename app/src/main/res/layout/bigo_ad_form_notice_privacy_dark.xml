<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:background="#ff000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp">
        <sg.bigo.ads.common.view.RoundedFrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:bigo_ad_radius="8dp">
            <LinearLayout
                android:orientation="vertical"
                android:background="#1c2933"
                android:paddingBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">
                <TextView
                    android:textSize="16sp"
                    android:textColor="#dae6f2"
                    android:id="@+id/inter_form_privacy_notice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="15dp"/>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <sg.bigo.ads.common.view.MixtureTextView
                        android:textSize="13sp"
                        android:textColor="#8595a6"
                        android:id="@+id/inter_form_privacy_desc"
                        android:paddingBottom="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <sg.bigo.ads.common.view.PrivacyCheckBox
                            android:id="@+id/inter_form_check_box"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:bigo_ad_hcb_is_check="true"
                            app:bigo_ad_hcb_style="hollow_out"
                            app:bigo_ad_hcb_uncheck_circle_color="#dde5e9"/>
                    </sg.bigo.ads.common.view.MixtureTextView>
                    <View
                        android:id="@+id/bigo_ad_check_box_expand"
                        android:layout_width="25dp"
                        android:layout_height="25dp"/>
                </RelativeLayout>
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:id="@+id/inter_privacy_btn_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">
                    <TextView
                        android:textSize="14sp"
                        android:textColor="#009dff"
                        android:gravity="center"
                        android:id="@+id/bigo_ad_form_btn_cancel"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:text="Cancel"
                        android:layout_weight="1"
                        android:textAllCaps="false"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="#ffffff"
                        android:gravity="center"
                        android:id="@+id/bigo_ad_form_btn_agree"
                        android:background="@drawable/bigo_ad_btn_background"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:text="I agree"
                        android:layout_weight="1"
                        android:textAllCaps="false"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>
            </LinearLayout>
        </sg.bigo.ads.common.view.RoundedFrameLayout>
    </LinearLayout>
</RelativeLayout>

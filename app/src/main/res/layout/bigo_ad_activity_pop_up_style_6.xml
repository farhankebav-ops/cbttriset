<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/inter_native_ad_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/media_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="100dp"
        android:layout_centerVertical="true"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp">
        <sg.bigo.ads.common.view.RoundedFrameLayout
            android:id="@+id/inter_media_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:bigo_ad_radius="16dp">
            <LinearLayout
                android:orientation="vertical"
                android:background="#ffffff"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <include
                    android:id="@+id/inter_popup_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7.5dp"
                    android:layout_marginStart="7.5dp"
                    android:layout_marginEnd="100dp"
                    layout="@layout/bigo_ad_pop_up_ad_msg"/>
                <sg.bigo.ads.common.view.RoundedFrameLayout
                    android:id="@+id/inter_media_rounded"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    app:bigo_ad_radius="8dp">
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <sg.bigo.ads.api.MediaView
                            android:id="@+id/inter_media"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minWidth="200dp"
                            android:minHeight="100dp"/>
                        <Button
                            android:id="@+id/inter_btn_mute"
                            android:background="@drawable/bigo_ad_ic_media_mute"
                            android:visibility="invisible"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginBottom="12dp"
                            android:layout_alignBottom="@+id/inter_media"
                            android:layout_marginEnd="12dp"
                            android:layout_alignEnd="@+id/inter_media"/>
                        <sg.bigo.ads.common.view.YandexWarningTextView
                            android:textColor="#99ffffff"
                            android:id="@+id/inter_warning"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:textScaleX="0.3"
                            android:maxLines="2"
                            android:shadowColor="#33000000"
                            android:shadowDx="0"
                            android:shadowDy="1"
                            android:shadowRadius="3"
                            android:layout_alignBottom="@+id/inter_media"
                            android:alpha="0.8"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"
                            app:bigo_ad_maxTextSize="130sp"
                            app:bigo_ad_minTextSize="10sp"/>
                    </RelativeLayout>
                </sg.bigo.ads.common.view.RoundedFrameLayout>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#202124"
                    android:ellipsize="end"
                    android:gravity="left"
                    android:id="@+id/inter_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:text="@string/bigo_ad_title_default"
                    android:lines="1"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </sg.bigo.ads.common.view.RoundedFrameLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/btn_class"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp">
            <include
                android:id="@+id/inter_popup_close_btn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                layout="@layout/bigo_ad_popup_close_btn"/>
            <sg.bigo.ads.common.view.RoundedFrameLayout
                android:id="@+id/inter_btn_cta_layout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                app:bigo_ad_radius="6dp">
                <Button
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:ellipsize="end"
                    android:id="@+id/inter_btn_cta"
                    android:background="@drawable/bigo_ad_button_bg_rectangle_blue"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/bigo_ad_cta_default"
                    android:maxLines="2"
                    android:textAllCaps="false"/>
            </sg.bigo.ads.common.view.RoundedFrameLayout>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/gift_widget"
        android:visibility="gone"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerVertical="true"
        android:translationY="-28dp"
        android:rotation="-15"
        android:layout_marginStart="-32dp"
        android:layout_alignStart="@+id/media_layout"/>
    <ImageView
        android:id="@+id/heart_widget"
        android:visibility="gone"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerVertical="true"
        android:translationY="28dp"
        android:rotation="15"
        android:layout_marginEnd="-32dp"
        android:layout_alignEnd="@+id/media_layout"/>
</RelativeLayout>

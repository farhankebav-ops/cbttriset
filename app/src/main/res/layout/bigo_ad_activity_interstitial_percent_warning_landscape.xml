<?xml version="1.0" encoding="utf-8"?>
<sg.bigo.ads.api.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/inter_native_ad_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/inter_ad_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/inter_media_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <sg.bigo.ads.common.view.RoundedFrameLayout
                android:layout_gravity="center"
                android:id="@+id/inter_media_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:bigo_ad_radius="8dp">
                <sg.bigo.ads.api.MediaView
                    android:id="@+id/inter_media"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <Button
                    android:layout_gravity="bottom|right"
                    android:id="@+id/inter_btn_mute"
                    android:background="@drawable/bigo_ad_ic_media_mute"
                    android:visibility="invisible"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginRight="12dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginEnd="12dp"/>
            </sg.bigo.ads.common.view.RoundedFrameLayout>
        </FrameLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:paddingRight="20dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:paddingEnd="20dp">
            <FrameLayout
                android:orientation="vertical"
                android:id="@+id/inter_ad_info_inner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <sg.bigo.ads.common.view.RoundedFrameLayout
                    android:id="@+id/inter_ad_info_background"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="50dp">
                            <sg.bigo.ads.common.view.RoundedFrameLayout
                                android:id="@+id/inter_rounded_icon_layout"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="20dp"
                                android:layout_marginStart="20dp"
                                app:bigo_ad_radius="8dp">
                                <ImageView
                                    android:id="@+id/inter_icon"
                                    android:layout_width="72dp"
                                    android:layout_height="72dp"/>
                            </sg.bigo.ads.common.view.RoundedFrameLayout>
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="20dp"
                                android:layout_marginStart="20dp">
                                <TextView
                                    android:textSize="21sp"
                                    android:textColor="#ffffff"
                                    android:ellipsize="end"
                                    android:id="@+id/inter_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/bigo_ad_title_default"
                                    android:lines="1"
                                    android:fontFamily="sans-serif-medium"/>
                                <TextView
                                    android:textSize="12sp"
                                    android:textColor="#9affffff"
                                    android:ellipsize="end"
                                    android:id="@+id/inter_description"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/bigo_ad_description_default"
                                    android:maxLines="2"/>
                            </LinearLayout>
                        </LinearLayout>
                        <sg.bigo.ads.ad.interstitial.multi_img.view.IconListView
                            android:id="@+id/inter_iconlist_download_msg_list"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"/>
                    </LinearLayout>
                </sg.bigo.ads.common.view.RoundedFrameLayout>
            </FrameLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <Button
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:ellipsize="end"
                    android:id="@+id/inter_btn_cta_main"
                    android:background="@drawable/bigo_ad_button_bg_rectangle_green"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:text="@string/bigo_ad_cta_default"
                    android:maxLines="1"
                    android:layout_weight="1"
                    android:textAllCaps="false"/>
                <sg.bigo.ads.common.view.RoundedFrameLayout
                    android:id="@+id/inter_btn_cta_layout"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="15dp"
                    android:layout_weight="1"
                    android:layout_marginStart="15dp"
                    app:bigo_ad_radius="6dp">
                    <Button
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        android:ellipsize="end"
                        android:id="@+id/inter_btn_cta"
                        android:background="@drawable/bigo_ad_button_bg_rectangle_blue"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="@string/bigo_ad_cta_default"
                        android:maxLines="1"
                        android:textAllCaps="false"/>
                </sg.bigo.ads.common.view.RoundedFrameLayout>
            </LinearLayout>
            <sg.bigo.ads.common.view.YandexWarningTextView
                android:textColor="#888888"
                android:gravity="top"
                android:id="@+id/inter_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp"
                android:textScaleX="0.3"
                android:maxLines="2"
                android:includeFontPadding="false"
                app:bigo_ad_maxTextSize="130sp"
                app:bigo_ad_minTextSize="10sp"/>
        </LinearLayout>
    </LinearLayout>
    <sg.bigo.ads.api.AdOptionsView
        android:layout_gravity="top|left"
        android:id="@+id/inter_options"
        android:layout_width="13dp"
        android:layout_height="13dp"
        android:layout_marginLeft="9dp"
        android:layout_marginTop="9dp"
        android:layout_marginStart="9dp"/>
    <TextView
        android:textSize="9sp"
        android:textColor="#ccffffff"
        android:gravity="center"
        android:layout_gravity="top|left"
        android:id="@+id/inter_ad_label"
        android:background="@drawable/bigo_ad_label_advertiser_background_raduis7"
        android:paddingLeft="6dp"
        android:paddingTop="1dp"
        android:paddingRight="6dp"
        android:paddingBottom="1dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="25dp"
        android:layout_marginTop="9dp"
        android:text="@string/bigo_ad_tag"
        android:layout_marginStart="25dp"/>
    <TextView
        android:textSize="13sp"
        android:textColor="#ffffff"
        android:ellipsize="end"
        android:id="@+id/inter_advertiser"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8.5dp"
        android:text="bigoad.com"
        android:maxLines="1"/>
</sg.bigo.ads.api.NativeAdView>

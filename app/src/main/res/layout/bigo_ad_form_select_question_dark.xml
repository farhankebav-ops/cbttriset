<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#1c2933"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RadioGroup
        android:orientation="vertical"
        android:id="@+id/inter_form_edit_content"
        android:background="@drawable/bigo_ad_edit_background_dark"
        android:paddingTop="20.5dp"
        android:paddingBottom="11dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"/>
    <TextView
        android:textSize="13sp"
        android:textColor="#dae6f2"
        android:id="@+id/inter_form_edit_title"
        android:background="#1c2933"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-7dp"
        android:layout_alignTop="@+id/inter_form_edit_content"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginStart="8dp"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#ff4d6a"
        android:id="@+id/inter_form_edit_warning"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_below="@+id/inter_form_edit_content"
        android:layout_marginStart="12dp"/>
</RelativeLayout>

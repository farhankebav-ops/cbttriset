<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <sg.bigo.ads.common.view.RoundedImageView
        android:id="@+id/inter_icon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/inter_text_layout"
        android:paddingLeft="8dp"
        android:layout_width="wrap_content"
        android:layout_height="72dp"
        android:layout_toRightOf="@+id/inter_icon">
        <LinearLayout
            android:gravity="top|left"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1">
            <TextView
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:id="@+id/inter_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bigo_ad_title_default"
                android:maxLines="2"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:id="@+id/inter_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bigo_ad_description_default"
                android:maxLines="1"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/inter_star"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:scaleType="fitStart"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/inter_more"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/bigo_ad_ic_right_black"
        android:layout_toRightOf="@+id/inter_text_layout"/>
</RelativeLayout>

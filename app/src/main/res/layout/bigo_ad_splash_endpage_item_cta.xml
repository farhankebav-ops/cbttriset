<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:id="@+id/bigo_ad_splash_btn_cta_container"
    android:clipChildren="false"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/splash_footer_bg"
        android:background="@drawable/bigo_ad_splash_header_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:rotation="180"/>
    <Button
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:ellipsize="end"
        android:id="@+id/bigo_ad_splash_btn_cta"
        android:background="@drawable/bigo_ad_button_bg_rectangle_green_radius8"
        android:clickable="false"
        android:layout_width="160dp"
        android:layout_height="40dp"
        android:text="@string/bigo_ad_cta_default"
        android:maxLines="1"
        android:shadowColor="#66000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:layout_centerHorizontal="true"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"/>
    <sg.bigo.ads.common.view.RoundedFrameLayout
        android:id="@+id/bigo_ad_splash_cta_inner"
        android:visibility="invisible"
        android:clipChildren="false"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_alignTop="@+id/bigo_ad_splash_btn_cta"
        android:layout_alignBottom="@+id/bigo_ad_splash_btn_cta"
        android:layout_alignStart="@+id/bigo_ad_splash_btn_cta"
        android:layout_alignEnd="@+id/bigo_ad_splash_btn_cta"
        android:elevation="2dp"
        app:bigo_ad_radius="20dp"/>
</RelativeLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/layout_contain_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <sg.bigo.ads.api.MediaView
            android:layout_gravity="center"
            android:id="@+id/bigo_ad_splash_media"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <RelativeLayout
            android:background="@drawable/bigo_ad_splash_header_bg"
            android:layout_width="match_parent"
            android:layout_height="80dp">
            <LinearLayout
                android:gravity="start|center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="16dp">
                <ImageView
                    android:id="@+id/bigo_ad_splash_icon"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:id="@+id/bigo_ad_splash_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bigo_ad_title_default"
                        android:lines="2"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="16dp"/>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
        <include layout="@layout/bigo_ad_splash_item_cta"/>
        <LinearLayout
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <include layout="@layout/bigo_ad_splash_ad_label"/>
            <TextView
                android:textSize="13sp"
                android:textColor="#d8d8d8"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/inter_warning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text=""
                android:maxLines="2"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>
            <sg.bigo.ads.api.AdOptionsView
                android:id="@+id/bigo_ad_splash_options"
                android:layout_width="16dp"
                android:layout_height="16dp"/>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>

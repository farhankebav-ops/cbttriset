<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/inter_native_ad_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/media_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="100dp"
        android:layout_centerVertical="true"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp">
        <sg.bigo.ads.common.view.RoundedFrameLayout
            android:id="@+id/inter_media_container"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:bigo_ad_radius="16dp">
            <RelativeLayout
                android:gravity="top|center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <sg.bigo.ads.api.MediaView
                    android:id="@+id/inter_media"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minWidth="200dp"
                    android:minHeight="100dp"
                    android:layout_centerInParent="true"/>
                <Button
                    android:id="@+id/inter_btn_mute"
                    android:background="@drawable/bigo_ad_ic_media_mute"
                    android:visibility="invisible"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginBottom="12dp"
                    android:layout_alignBottom="@+id/inter_media"
                    android:layout_marginEnd="12dp"
                    android:layout_alignEnd="@+id/inter_media"/>
                <sg.bigo.ads.common.view.YandexWarningTextView
                    android:textColor="#99ffffff"
                    android:id="@+id/inter_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:textScaleX="0.3"
                    android:maxLines="2"
                    android:includeFontPadding="false"
                    android:shadowColor="#33000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:layout_alignBottom="@+id/inter_media"
                    android:alpha="0.8"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    app:bigo_ad_maxTextSize="130sp"
                    app:bigo_ad_minTextSize="10sp"/>
                <include
                    android:id="@+id/inter_popup_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7.5dp"
                    android:layout_alignTop="@+id/inter_media"
                    android:layout_marginStart="7.5dp"
                    android:layout_marginEnd="100dp"
                    android:layout_alignStart="@+id/inter_media"
                    layout="@layout/bigo_ad_pop_up_ad_msg"/>
            </RelativeLayout>
        </sg.bigo.ads.common.view.RoundedFrameLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/inter_ad_info"
            android:background="@drawable/bigo_ad_popup_ad_info_background"
            android:padding="10dp"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <sg.bigo.ads.common.view.RoundedFrameLayout
                    android:layout_gravity="center"
                    android:id="@+id/icon_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:bigo_ad_radius="8dp">
                    <ImageView
                        android:id="@+id/inter_icon"
                        android:layout_width="44dp"
                        android:layout_height="44dp"/>
                </sg.bigo.ads.common.view.RoundedFrameLayout>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#202124"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/inter_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bigo_ad_title_default"
                    android:lines="1"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="104dp"
                    android:layout_toEndOf="@+id/icon_layout"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="#202124"
                    android:ellipsize="end"
                    android:id="@+id/inter_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:lines="1"
                    android:layout_below="@+id/inter_title"
                    android:layout_toStartOf="@+id/inter_btn_cta_layout"
                    android:layout_alignStart="@+id/inter_title"/>
                <sg.bigo.ads.common.view.RoundedFrameLayout
                    android:id="@+id/inter_btn_cta_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginStart="12dp"
                    android:layout_alignParentEnd="true"
                    app:bigo_ad_radius="8dp">
                    <Button
                        android:textSize="16sp"
                        android:textColor="@android:color/white"
                        android:ellipsize="end"
                        android:id="@+id/inter_btn_cta"
                        android:background="@drawable/bigo_ad_button_bg_rectangle_blue"
                        android:layout_width="80dp"
                        android:layout_height="44dp"
                        android:text="@string/bigo_ad_cta_default"
                        android:maxLines="1"
                        android:textAllCaps="false"/>
                </sg.bigo.ads.common.view.RoundedFrameLayout>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/gift_widget"
        android:visibility="gone"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerVertical="true"
        android:translationY="-28dp"
        android:rotation="-15"
        android:layout_marginStart="-32dp"
        android:layout_alignStart="@+id/media_layout"/>
    <ImageView
        android:id="@+id/heart_widget"
        android:visibility="gone"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerVertical="true"
        android:translationY="28dp"
        android:rotation="15"
        android:layout_marginEnd="-32dp"
        android:layout_alignEnd="@+id/media_layout"/>
    <sg.bigo.ads.ad.interstitial.AdCountDownButton
        android:id="@+id/inter_btn_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-84dp"
        android:layout_below="@+id/media_layout"
        android:layout_centerHorizontal="true"
        app:bigo_ad_customLayout="@layout/bigo_ad_item_inter_countdown_bg"/>
</RelativeLayout>

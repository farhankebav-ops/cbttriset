<?xml version="1.0" encoding="utf-8"?>
<sg.bigo.ads.common.view.RoundedFrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#1c2933"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:bigo_ad_radius="8dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/bigo_ad_success"/>
        <TextView
            android:textSize="20sp"
            android:textColor="#dae6f2"
            android:id="@+id/inter_feedback_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:textAlignment="center"/>
        <TextView
            android:textSize="13sp"
            android:textColor="#8595a6"
            android:id="@+id/inter_feedback_dec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAlignment="center"/>
        <Button
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:id="@+id/inter_feedback_cta"
            android:background="@drawable/bigo_ad_btn_background"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="20dp"
            android:textAllCaps="false"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>
    </LinearLayout>
</sg.bigo.ads.common.view.RoundedFrameLayout>

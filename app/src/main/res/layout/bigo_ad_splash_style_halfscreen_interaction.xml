<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/layout_contain_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <sg.bigo.ads.api.MediaView
                    android:id="@+id/bigo_ad_splash_media"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>
            <FrameLayout
                android:id="@+id/layout_ad_component"
                android:background="@android:color/white"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="80dp">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginLeft="32dp"
                    android:layout_marginRight="32dp"
                    android:layout_centerInParent="true"
                    android:layout_marginHorizontal="32dp">
                    <ImageView
                        android:id="@+id/bigo_ad_splash_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="15sp"
                            android:textColor="#333333"
                            android:ellipsize="end"
                            android:gravity="center_vertical"
                            android:id="@+id/bigo_ad_splash_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bigo_ad_title_default"
                            android:lines="2"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="16dp"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_gravity="bottom"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <include layout="@layout/bigo_ad_splash_ad_label"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="#d8d8d8"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:id="@+id/inter_warning"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:maxLines="2"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"/>
                    <sg.bigo.ads.api.AdOptionsView
                        android:layout_gravity="end|bottom"
                        android:id="@+id/bigo_ad_splash_options"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginBottom="9dp"/>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
    <FrameLayout
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/inter_fl_interaction_container"
        android:background="@drawable/bigo_ad_interaction_animation_bg"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"/>
</FrameLayout>

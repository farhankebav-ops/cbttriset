<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="25dp"
    android:layout_marginEnd="25dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="5dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp">
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:gravity="center"
                android:id="@+id/txt_judul"
                android:paddingLeft="@dimen/spacing_mlarge"
                android:paddingRight="@dimen/spacing_mlarge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Input Token"
                android:textAlignment="center"/>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp">
            <com.google.android.material.textfield.TextInputLayout
                android:textColorHint="@color/cardview_dark_background"
                android:id="@+id/lyt_input_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/colorPrimary"
                app:hintAnimationEnabled="true"
                app:hintTextColor="@color/colorPrimary">
                <com.google.android.material.textfield.TextInputEditText
                    android:textColor="@color/cardview_dark_background"
                    android:id="@+id/input_token"
                    android:padding="5dp"
                    android:focusable="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="150dp"
                    android:minHeight="55dp"
                    android:hint="token"/>
            </com.google.android.material.textfield.TextInputLayout>
        </RelativeLayout>
        <View
            android:id="@+id/view"
            android:background="@color/overlay_dark_20"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/color_dark_background"
            android:gravity="center"
            android:id="@+id/txt_msg"
            android:paddingLeft="@dimen/spacing_mlarge"
            android:paddingRight="@dimen/spacing_mlarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Input Token"
            android:textAlignment="center"/>
        <View
            android:id="@+id/view9"
            android:background="@color/overlay_dark_20"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="5dp"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/lyt_action"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">
            <androidx.appcompat.widget.AppCompatButton
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:id="@+id/bt_cancel"
                android:background="@drawable/btn_rounded_red"
                android:paddingLeft="@dimen/spacing_mlarge"
                android:paddingRight="@dimen/spacing_mlarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_dialog_cancel"
                style="@style/Widget.AppCompat.Button.Borderless"/>
            <androidx.appcompat.widget.AppCompatButton
                android:textSize="12dp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:id="@+id/bt_open"
                android:background="@drawable/btn_rounded_primary"
                android:paddingLeft="@dimen/spacing_mlarge"
                android:paddingRight="@dimen/spacing_mlarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_token_btn"
                style="@style/Widget.AppCompat.Button.Borderless"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

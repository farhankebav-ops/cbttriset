<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="5dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:padding="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                android:minHeight="?attr/actionBarSize">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="30dp">
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textStyle="bold"
                        android:textColor="@color/yellow_900"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Custom useragent"/>
                    <View
                        android:layout_width="@dimen/spacing_middle"
                        android:layout_height="wrap_content"/>
                    <View
                        android:layout_width="@dimen/spacing_middle"
                        android:layout_height="wrap_content"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_useragent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:checked="false"
                        app:thumbTint="@color/switch_color_primary"/>
                </LinearLayout>
                <TextView
                    android:textAppearance="@style/TextAppearance.AppCompat.Small"
                    android:textColor="@color/grey_40"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="useragent = cbt-exam-browser "/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:id="@+id/view"
            android:background="@color/overlay_dark_20"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_gravity="center"
            android:id="@+id/bt_cancel"
            android:background="@drawable/btn_rounded_primary"
            android:paddingLeft="@dimen/spacing_mlarge"
            android:paddingRight="@dimen/spacing_mlarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_dialog_close"
            style="@style/Widget.AppCompat.Button.Borderless"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>

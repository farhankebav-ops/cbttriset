<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center_horizontal"
    android:orientation="horizontal"
    android:id="@+id/interaction_root"
    android:clipChildren="false"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginBottom="25dp">
    <FrameLayout
        android:id="@+id/inter_fl_interaction"
        android:clipChildren="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/inter_iv_interaction_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/bigo_ad_interaction_shake_arrow"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/inter_iv_interaction_phone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/bigo_ad_interaction_shake_landscape_phone"/>
    </FrameLayout>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp">
        <TextView
            android:textSize="24sp"
            android:textColor="#ffffff"
            android:layout_gravity="start"
            android:id="@+id/inter_tv_interaction_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bigo_ad_interaction_slide"/>
        <TextView
            android:textSize="13sp"
            android:textColor="#ffffff"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/bigo_ad_interaction_jump_hint"/>
    </LinearLayout>
</LinearLayout>

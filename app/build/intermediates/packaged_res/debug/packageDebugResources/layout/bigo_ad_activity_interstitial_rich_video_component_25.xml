<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/inter_component_layout"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <sg.bigo.ads.common.view.RoundedImageView
        android:id="@+id/inter_icon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"/>
    <Button
        android:textSize="14sp"
        android:textColor="#ff202124"
        android:ellipsize="end"
        android:id="@+id/inter_btn_cta"
        android:background="#ffffffff"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:layout_width="120dp"
        android:layout_height="72dp"
        android:layout_marginLeft="7dp"
        android:text="@string/bigo_ad_cta_default"
        android:maxLines="1"
        android:layout_toRightOf="@+id/inter_icon"
        android:textAllCaps="false"/>
</RelativeLayout>

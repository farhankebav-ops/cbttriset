<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_contain_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/inter_media_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="20dp">
            <sg.bigo.ads.common.view.RoundedFrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:bigo_ad_radius="8dp"
                app:bigo_ad_shadowColor="#29000000"
                app:bigo_ad_shadowRadius="8dp">
                <ImageView
                    android:id="@+id/bigo_ad_splash_icon"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="55dp"
                    android:layout_height="55dp"/>
            </sg.bigo.ads.common.view.RoundedFrameLayout>
            <TextView
                android:textSize="20sp"
                android:textColor="#333333"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:id="@+id/bigo_ad_splash_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:text="@string/bigo_ad_title_default"
                android:lines="1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
        <sg.bigo.ads.common.view.ViewFlow
            android:id="@+id/inter_media_ad_view_flow"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <sg.bigo.ads.common.view.Indicator
            android:layout_gravity="center"
            android:id="@+id/vf_indicator"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>
        <include layout="@layout/bigo_ad_splash_style_3_item_cta"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="9.5dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="9.5dp"
            android:layout_marginBottom="8dp">
            <include
                android:layout_gravity="start|bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                layout="@layout/bigo_ad_splash_ad_label"/>
            <TextView
                android:textSize="13sp"
                android:textColor="#d8d8d8"
                android:ellipsize="end"
                android:layout_gravity="center_vertical"
                android:id="@+id/inter_warning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text=""
                android:maxLines="2"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"/>
            <sg.bigo.ads.api.AdOptionsView
                android:layout_gravity="end|bottom"
                android:id="@+id/bigo_ad_splash_options"
                android:layout_width="16dp"
                android:layout_height="16dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>

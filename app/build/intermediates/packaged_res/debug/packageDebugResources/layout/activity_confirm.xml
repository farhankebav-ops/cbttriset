<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/rel_bawah">
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.Toolbar
                android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
                android:id="@+id/toolbar"
                android:background="@color/color_light_primary"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:contentInsetStartWithNavigation="0dp"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light"/>
        </com.google.android.material.appbar.AppBarLayout>
        <androidx.core.widget.NestedScrollView
            android:background="@color/white"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollingCache="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RelativeLayout
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/img_logo"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        app:srcCompat="@drawable/confirm"/>
                </RelativeLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Large"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_light_primary"
                            android:gravity="center"
                            android:id="@+id/txt_judul"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="@string/app_name"/>
                        <LinearLayout
                            android:orientation="vertical"
                            android:background="@drawable/bg_border_blue"
                            android:padding="5dp"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:textStyle="bold"
                                android:textColor="@color/color_light_primary"
                                android:gravity="center"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Masa Aktif QR CODE"/>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:orientation="horizontal"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent">
                                <TextView
                                    android:textColor="@color/color_light_primary"
                                    android:layout_width="55dp"
                                    android:layout_height="wrap_content"
                                    android:text="Dari       :"/>
                                <TextView
                                    android:textStyle="bold"
                                    android:textColor="@color/color_light_primary"
                                    android:id="@+id/tgl_mulai"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="17-08-2023"
                                    android:layout_marginStart="1dp"
                                    android:layout_marginEnd="2dp"/>
                                <TextView
                                    android:textStyle="bold"
                                    android:textColor="@color/color_light_primary"
                                    android:id="@+id/jam_mulai"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="17:00"
                                    android:layout_marginStart="1dp"
                                    android:layout_marginEnd="2dp"/>
                            </LinearLayout>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:orientation="horizontal"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent">
                                <TextView
                                    android:textColor="@color/color_light_primary"
                                    android:layout_width="55dp"
                                    android:layout_height="wrap_content"
                                    android:text="Sampai :"/>
                                <TextView
                                    android:textStyle="bold"
                                    android:textColor="@color/color_light_primary"
                                    android:id="@+id/tgl_akhir"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="18-08-2023"
                                    android:layout_marginStart="1dp"
                                    android:layout_marginEnd="2dp"/>
                                <TextView
                                    android:textStyle="bold"
                                    android:textColor="@color/color_light_primary"
                                    android:id="@+id/jam_akhir"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="18:00"
                                    android:layout_marginStart="1dp"
                                    android:layout_marginEnd="2dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/lyt_lamaujian"
                        android:background="@drawable/bg_border_red"
                        android:padding="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp">
                        <TextView
                            android:textSize="13sp"
                            android:textColor="@color/red_400"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_scanqr_waktuujian"/>
                        <TextView
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/red_400"
                            android:gravity="center"
                            android:id="@+id/lamates"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:text="0 Menit"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/lyt_pesan"
                        android:background="@drawable/bg_border"
                        android:padding="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp">
                        <TextView
                            android:textSize="13sp"
                            android:textColor="@color/yellow_900"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_customqr_msg"/>
                        <TextView
                            android:textColor="@color/yellow_900"
                            android:gravity="center"
                            android:id="@+id/pesan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:layout_marginBottom="1dp"
                            android:maxHeight="80dp"
                            android:minHeight="20dp"
                            android:text="test"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
    <RelativeLayout
        android:gravity="center"
        android:id="@+id/rel_bawah"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.balysv.materialripple.MaterialRippleLayout
                android:id="@+id/btn_masukujian"
                android:background="@color/color_light_primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_xxlarge"
                style="@style/RippleStyleWhite">
                <TextView
                    android:textAppearance="@style/Base.TextAppearance.AppCompat.Subhead"
                    android:textSize="20sp"
                    android:textColor="@android:color/white"
                    android:layout_gravity="center"
                    android:id="@+id/txt_masukujian"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_scanqr_masukujian"
                    app:fontFamily="sans-serif-medium"/>
            </com.balysv.materialripple.MaterialRippleLayout>
            <com.mimikridev.ads.ui.BannerAdView
                android:id="@+id/bannerAdView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>

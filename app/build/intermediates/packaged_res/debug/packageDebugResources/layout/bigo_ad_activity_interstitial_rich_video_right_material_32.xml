<?xml version="1.0" encoding="utf-8"?>
<sg.bigo.ads.api.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/inter_native_ad_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/native_view"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:id="@+id/inter_media_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/iv_media_blur_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"/>
            <View
                android:id="@+id/iv_media_blur_bg_mask"
                android:background="#a6000000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <sg.bigo.ads.api.MediaView
                android:layout_gravity="start"
                android:id="@+id/inter_media"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <View
                android:id="@+id/bigo_ad_mask_vertical"
                android:background="@drawable/bigo_ad_multi_img_vertical_mask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <View
                android:id="@+id/bigo_ad_mask_horizontal"
                android:background="@drawable/bigo_ad_multi_img_horizontal_mask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/bigo_ad_material_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="21.5sp"
                    android:textColor="#202124"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:layout_gravity="end"
                    android:id="@+id/inter_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="18dp"
                    android:layout_marginRight="18dp"
                    android:text="@string/bigo_ad_title_default"
                    android:maxLines="2"
                    android:fontFamily="sans-serif-medium"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_gravity="end"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="18dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginRight="18dp">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="18dp">
                        <TextView
                            android:textSize="12sp"
                            android:textColor="#5f6367"
                            android:ellipsize="end"
                            android:id="@+id/inter_description"
                            android:layout_width="98dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/bigo_ad_description_default"
                            android:maxLines="3"/>
                        <ImageView
                            android:id="@+id/inter_star"
                            android:layout_width="88dp"
                            android:layout_height="15dp"
                            android:layout_marginTop="5dp"/>
                    </LinearLayout>
                    <sg.bigo.ads.common.view.RoundedImageView
                        android:id="@+id/inter_icon"
                        android:layout_width="72dp"
                        android:layout_height="72dp"/>
                </LinearLayout>
                <sg.bigo.ads.common.view.RoundedFrameLayout
                    android:layout_gravity="end"
                    android:id="@+id/inter_btn_cta_layout"
                    android:layout_width="188dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    app:bigo_ad_radius="8dp">
                    <Button
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        android:ellipsize="end"
                        android:id="@+id/inter_btn_cta"
                        android:background="#ff1b8863"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/bigo_ad_cta_default"
                        android:maxLines="1"
                        android:textAllCaps="false"/>
                </sg.bigo.ads.common.view.RoundedFrameLayout>
                <sg.bigo.ads.common.view.RoundedFrameLayout
                    android:id="@+id/fl_multi_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    app:bigo_ad_radius="4dp">
                    <ImageView
                        android:id="@+id/iv_blur_bg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleType="fitXY"/>
                    <HorizontalScrollView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/bigo_ad_scroll_images"
                        android:scrollbars="none"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </sg.bigo.ads.common.view.RoundedFrameLayout>
                <sg.bigo.ads.common.view.YandexWarningTextView
                    android:textColor="#59888888"
                    android:gravity="top"
                    android:id="@+id/inter_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="18dp"
                    android:layout_marginTop="28dp"
                    android:layout_marginRight="18dp"
                    android:textScaleX="0.3"
                    android:maxLines="2"
                    android:includeFontPadding="false"
                    app:bigo_ad_maxTextSize="100sp"
                    app:bigo_ad_minTextSize="10sp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/ll_native_extra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="18dp"
                    android:layout_marginRight="18dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="#202124"
                            android:layout_gravity="center"
                            android:id="@+id/tv_gp_info_extra_about"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bigo_ad_about_app_default"
                            android:fontFamily="sans-serif-medium"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/iv_gp_info_extra_arrow"
                            android:background="@drawable/bigo_ad_mid_page_ic_gp_right"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                    </FrameLayout>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="#63666b"
                        android:ellipsize="end"
                        android:id="@+id/tv_desc_below"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"/>
                    <sg.bigo.ads.common.view.AutoNextLineLinearLayout
                        android:id="@+id/fbl_genre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:layout_marginBottom="20dp"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </ScrollView>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp">
        <sg.bigo.ads.api.AdOptionsView
            android:id="@+id/inter_options"
            android:layout_width="16dp"
            android:layout_height="16dp"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bigo_ad_label_advertiser_background_raduis7"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="3dp">
            <TextView
                android:textSize="9sp"
                android:textColor="#ccffffff"
                android:gravity="center"
                android:id="@+id/inter_ad_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bigo_ad_tag"/>
            <TextView
                android:textSize="9sp"
                android:textColor="#e9ebec"
                android:ellipsize="end"
                android:id="@+id/inter_advertiser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="240dp"
                android:text="bigoad.com"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>
</sg.bigo.ads.api.NativeAdView>

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/inter_layout_end_page"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/inter_end_page"
        android:paddingLeft="32dp"
        android:paddingTop="60dp"
        android:paddingRight="32dp"
        android:paddingBottom="60dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/word_icon_container">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/inter_icon_layout"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <sg.bigo.ads.common.view.RoundedImageView
                android:id="@+id/inter_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"/>
            <TextView
                android:textSize="21.5sp"
                android:textColor="#333333"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/inter_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="14.5dp"
                android:text="@string/bigo_ad_title_default"
                android:maxLines="1"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
        <FrameLayout
            android:id="@+id/inter_end_page_image_layout"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_weight="1">
            <sg.bigo.ads.common.view.RoundedImageView
                android:id="@+id/inter_end_page_image_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <sg.bigo.ads.common.view.RoundedImageView
                android:id="@+id/inter_end_page_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </FrameLayout>
        <Button
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:id="@+id/inter_btn_cta"
            android:background="@drawable/bigo_ad_button_bg_rectangle_blue"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/bigo_ad_cta_default"
            android:maxLines="1"
            android:textAllCaps="false"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/word_icon_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"/>
    <include layout="@layout/bigo_ad_layout_interstitial_ad_mark_top_left"/>
    <include
        android:id="@+id/inter_warning_layout"
        layout="@layout/bigo_ad_layout_interstitial_ad_warning_bottom"/>
</RelativeLayout>

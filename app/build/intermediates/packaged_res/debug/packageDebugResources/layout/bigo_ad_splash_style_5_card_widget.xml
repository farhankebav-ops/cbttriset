<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_contain_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <sg.bigo.ads.common.view.RoundedFrameLayout
                android:layout_gravity="bottom|center_horizontal"
                android:id="@+id/bigo_ad_splash_btn_cta_container_round"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:bigo_ad_radius="12dp"
                app:bigo_ad_shadowColor="#29000000"
                app:bigo_ad_shadowRadius="8dp">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:id="@+id/layout_cta_widget_inner"
                    android:background="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16dp"
                        android:layout_marginStart="16dp">
                        <sg.bigo.ads.common.view.RoundedFrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:bigo_ad_radius="8dp">
                            <ImageView
                                android:id="@+id/bigo_ad_splash_icon"
                                android:focusable="true"
                                android:clickable="true"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>
                        </sg.bigo.ads.common.view.RoundedFrameLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:textSize="18sp"
                                android:textColor="#333333"
                                android:ellipsize="end"
                                android:gravity="center_vertical"
                                android:id="@+id/bigo_ad_splash_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/bigo_ad_title_default"
                                android:lines="1"
                                android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:textSize="13sp"
                                android:textColor="#333333"
                                android:ellipsize="end"
                                android:id="@+id/bigo_ad_splash_description"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="@string/bigo_ad_description_default"
                                android:maxLines="1"/>
                        </LinearLayout>
                        <RelativeLayout
                            android:id="@+id/bigo_ad_splash_btn_cta_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginRight="16dp"
                            android:layout_marginBottom="16dp"
                            android:layout_marginEnd="16dp">
                            <Button
                                android:textSize="14sp"
                                android:textColor="@android:color/white"
                                android:ellipsize="end"
                                android:id="@+id/bigo_ad_splash_btn_cta"
                                android:background="@drawable/bigo_ad_button_bg_rectangle_green_radius8"
                                android:clickable="false"
                                android:layout_width="120dp"
                                android:layout_height="44dp"
                                android:layout_marginLeft="10dp"
                                android:text="@string/bigo_ad_cta_default"
                                android:maxLines="1"
                                android:textAllCaps="false"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="10dp"/>
                            <sg.bigo.ads.common.view.RoundedFrameLayout
                                android:id="@+id/bigo_ad_splash_cta_inner"
                                android:visibility="invisible"
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_alignLeft="@+id/bigo_ad_splash_btn_cta"
                                android:layout_alignTop="@+id/bigo_ad_splash_btn_cta"
                                android:layout_alignRight="@+id/bigo_ad_splash_btn_cta"
                                android:layout_alignBottom="@+id/bigo_ad_splash_btn_cta"
                                android:layout_alignStart="@+id/bigo_ad_splash_btn_cta"
                                android:layout_alignEnd="@+id/bigo_ad_splash_btn_cta"
                                android:elevation="2dp"
                                app:bigo_ad_radius="8dp"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </sg.bigo.ads.common.view.RoundedFrameLayout>
            <sg.bigo.ads.common.view.RoundedFrameLayout
                android:layout_gravity="center"
                android:id="@+id/bigo_ad_splash_media_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="20dp"
                app:bigo_ad_radius="8dp">
                <sg.bigo.ads.api.MediaView
                    android:layout_gravity="center"
                    android:id="@+id/bigo_ad_splash_media"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </sg.bigo.ads.common.view.RoundedFrameLayout>
        </FrameLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="9.5dp"
            android:layout_marginRight="9.5dp"
            android:layout_marginBottom="8dp">
            <include
                android:layout_gravity="start|center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                layout="@layout/bigo_ad_splash_ad_label"/>
            <TextView
                android:textSize="13sp"
                android:textColor="#d8d8d8"
                android:ellipsize="end"
                android:layout_gravity="center_vertical"
                android:id="@+id/inter_warning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text=""
                android:maxLines="2"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"/>
            <sg.bigo.ads.api.AdOptionsView
                android:layout_gravity="end|center_vertical"
                android:id="@+id/bigo_ad_splash_options"
                android:layout_width="16dp"
                android:layout_height="16dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:theme="@style/AppTheme"
    android:id="@+id/parent_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/rel_top"
            android:background="@color/navexam"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/lyt_logo"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:paddingStart="7dp"
                    android:paddingEnd="3dp">
                    <ImageView
                        android:id="@+id/logo"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@drawable/icon"
                        android:layout_marginEnd="5dp"/>
                    <LinearLayout
                        android:gravity="left"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:id="@+id/nama_sekolah"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:id="@+id/nama_ujian"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name_ujian"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/lyt_timer"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center"
                        android:id="@+id/img_timer"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        app:srcCompat="@drawable/baseline_timer_24"
                        app:tint="@color/navexam_white"/>
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/navexam_white"
                        android:gravity="center"
                        android:id="@+id/waktu_ujian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00 : 00 : 00"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/lytkonten"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/lytad"
            android:layout_below="@+id/rel_top">
            <WebView
                android:layout_gravity="center"
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <ProgressBar
                android:theme="@style/Loading"
                android:id="@+id/loading_icon"
                android:padding="1dp"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_centerInParent="true"/>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/rel_url_error"
                android:background="@color/white"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/imageView4"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        app:srcCompat="@drawable/error"/>
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textSize="16sp"
                        android:textColor="@color/red_A200"
                        android:gravity="center"
                        android:id="@+id/txt_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_exam_error_msg"
                        android:maxLines="3"/>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_error"
                        android:focusable="true"
                        android:clickable="true"
                        android:layout_width="90dp"
                        android:layout_height="50dp"
                        android:foreground="@drawable/ripple_effect"
                        app:cardBackgroundColor="@color/color_light_primary"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:textAppearance="@style/Base.TextAppearance.AppCompat.Subhead"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_exam_cobalagi"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/rel_offline"
                android:background="@color/white"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        app:srcCompat="@drawable/offline"/>
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textSize="13sp"
                        android:textColor="@color/red_A100"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_exam_error_offline"
                        android:maxLines="3"/>
                </LinearLayout>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/rel_pinlayar"
                android:background="@color/navexam"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="30dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/layout_stroke2"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="15sp"
                            android:textColor="@color/navexam_red"
                            android:gravity="center"
                            android:id="@+id/textView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:text="@string/txt_exam_pin_msg"/>
                        <androidx.cardview.widget.CardView
                            android:layout_gravity="center"
                            android:id="@+id/btn_pinlayar"
                            android:focusable="true"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="50dp"
                            android:foreground="@drawable/ripple_effect"
                            app:cardBackgroundColor="@color/color_light_primary"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="2dp"
                            app:cardUseCompatPadding="true"
                            app:contentPadding="10dp">
                            <LinearLayout
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <TextView
                                    android:textAppearance="@style/Base.TextAppearance.AppCompat.Subhead"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/txt_exam_pin"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/rel_penalty"
                android:background="@color/navexam"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/yellow_500"
                        android:gravity="center"
                        android:id="@+id/textView3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_penalty"/>
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        app:srcCompat="@drawable/yellowcard"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp">
                        <TextView
                            android:textSize="36sp"
                            android:textColor="@color/red_500"
                            android:gravity="center"
                            android:id="@+id/txt_penalty_countdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="00:59"/>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/yellow_600"
                                android:gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_penalty_count"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/yellow_600"
                                android:gravity="center"
                                android:id="@+id/txt_penaltycount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" "/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/yellow_600"
                                android:gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_penalty_start"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/red_500"
                                android:gravity="center"
                                android:id="@+id/txt_penaltyterakhir"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:textSize="14sp"
                                android:textColor="@color/yellow_600"
                                android:gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_penalty_reset"/>
                            <TextView
                                android:textSize="14sp"
                                android:textColor="@color/green_500"
                                android:gravity="center"
                                android:id="@+id/txt_penaltyreset"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""/>
                        </LinearLayout>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/red_500"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_penalty_info"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/layout_stroke"
                        android:padding="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:gravity="left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:text="@string/txt_note"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:gravity="left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:text="@string/txt_penalty_info1"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:gravity="left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:text="@string/txt_penalty_info2"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:gravity="left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:text="@string/txt_penalty_info3"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:gravity="left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:text="@string/txt_penalty_info4"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </RelativeLayout>
        <RelativeLayout
            android:gravity="center"
            android:id="@+id/lytad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/rel_bawah">
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/navexam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="50"
                    android:indeterminate="false"
                    android:progressDrawable="@drawable/progressbar_primary"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:layout_alignParentBottom="true"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
            </LinearLayout>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/bannerlyt"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </RelativeLayout>
        <RelativeLayout
            android:gravity="center"
            android:id="@+id/rel_bawah"
            android:background="@color/navexam"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_alignParentBottom="true">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_exit"
                        android:focusable="true"
                        android:clickable="true"
                        android:layout_width="75dp"
                        android:layout_height="50dp"
                        android:foreground="@drawable/ripple_effect"
                        app:cardBackgroundColor="@color/navexam_red"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="1dp"
                            android:layout_marginBottom="1dp"
                            android:layout_marginStart="1dp"
                            android:layout_marginEnd="1dp"
                            app:cardBackgroundColor="@color/navexam"
                            app:cardCornerRadius="5dp"
                            app:cardElevation="2dp">
                            <LinearLayout
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <RelativeLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent">
                                    <ImageView
                                        android:visibility="gone"
                                        android:layout_width="35dp"
                                        android:layout_height="35dp"
                                        android:layout_centerHorizontal="true"
                                        app:srcCompat="@drawable/ic_baseline_exit_to_app_24"
                                        app:tint="@color/red_600"/>
                                </RelativeLayout>
                                <TextView
                                    android:textAppearance="@style/Base.TextAppearance.AppCompat.Subhead"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/navexam_red"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/btn_dialog_exit"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_home"
                        android:focusable="true"
                        android:visibility="visible"
                        android:clickable="true"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:foreground="@drawable/ripple_effect"
                        app:cardBackgroundColor="@color/navexam_white"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">
                        <RelativeLayout
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_centerInParent="true"
                                app:srcCompat="@drawable/ic_baseline_home_24"
                                app:tint="@color/navexam"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_back"
                        android:focusable="true"
                        android:visibility="visible"
                        android:clickable="true"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:foreground="@drawable/ripple_effect"
                        app:cardBackgroundColor="@color/navexam_white"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">
                        <RelativeLayout
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_centerInParent="true"
                                app:srcCompat="@drawable/ic_baseline_arrow_back_24"
                                app:tint="@color/navexam"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_refresh"
                        android:focusable="true"
                        android:visibility="visible"
                        android:clickable="true"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:foreground="@drawable/ripple_effect"
                        app:cardBackgroundColor="@color/navexam_white"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">
                        <RelativeLayout
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_centerInParent="true"
                                app:srcCompat="@drawable/ic_baseline_refresh_24"
                                app:tint="@color/navexam"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_forward"
                        android:focusable="true"
                        android:visibility="visible"
                        android:clickable="true"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:foreground="@drawable/ripple_effect"
                        app:cardBackgroundColor="@color/navexam_white"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">
                        <RelativeLayout
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_centerInParent="true"
                                app:srcCompat="@drawable/ic_baseline_arrow_forward_24"
                                app:tint="@color/navexam"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:focusable="true"
                        android:clickable="true"
                        android:layout_width="75dp"
                        android:layout_height="50dp"
                        android:foreground="@drawable/ripple_effect"
                        app:cardBackgroundColor="@color/navexam_white"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="1dp"
                            android:layout_marginBottom="1dp"
                            android:layout_marginStart="1dp"
                            android:layout_marginEnd="1dp"
                            app:cardBackgroundColor="@color/navexam"
                            app:cardCornerRadius="5dp"
                            app:cardElevation="2dp">
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <RelativeLayout
                                    android:gravity="center"
                                    android:id="@+id/lyt_waktu_ujian"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <LinearLayout
                                        android:gravity="center"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">
                                        <ImageView
                                            android:id="@+id/type_jaringan"
                                            android:layout_width="13dp"
                                            android:layout_height="13dp"
                                            android:layout_marginEnd="2dp"
                                            app:tint="@color/navexam_white"/> /&gt; 
                                        <DigitalClock
                                            android:textSize="12sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/navexam_white"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:inputType="date"/>
                                    </LinearLayout>
                                </RelativeLayout>
                                <View
                                    android:layout_gravity="center"
                                    android:id="@+id/divider"
                                    android:background="@color/navexam_white"
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"/>
                                <LinearLayout
                                    android:gravity="center"
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <ImageView
                                        android:layout_gravity="center"
                                        android:layout_width="18dp"
                                        android:layout_height="13dp"
                                        android:layout_marginTop="1dp"
                                        android:layout_marginEnd="-1dp"
                                        app:srcCompat="@drawable/ic_baseline_battery_std_24"
                                        app:tint="@color/navexam_white"/>
                                    <TextView
                                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/navexam_white"
                                        android:gravity="center"
                                        android:id="@+id/batterai_stat"
                                        android:layout_width="wrap_content"
                                        android:layout_height="13dp"
                                        android:text="50 %"/>
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
        <View
            android:id="@+id/viewtop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </RelativeLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

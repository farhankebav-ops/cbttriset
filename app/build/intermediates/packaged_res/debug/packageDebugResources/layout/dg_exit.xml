<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="5dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:padding="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/overlay_dark_60"
                android:gravity="center"
                android:id="@+id/textView2"
                android:paddingLeft="@dimen/spacing_mlarge"
                android:paddingRight="@dimen/spacing_mlarge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:text="@string/txt_dialog_exit"/>
        </LinearLayout>
        <View
            android:id="@+id/view"
            android:background="@color/overlay_dark_20"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:id="@+id/bt_exit"
            android:background="@drawable/btn_rounded_red"
            android:paddingLeft="@dimen/spacing_mlarge"
            android:paddingRight="@dimen/spacing_mlarge"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_dialog_exit"
            style="@style/Widget.AppCompat.Button.Borderless"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_gravity="center"
            android:id="@+id/bt_cancel"
            android:background="@drawable/btn_rounded_primary"
            android:paddingLeft="@dimen/spacing_mlarge"
            android:paddingRight="@dimen/spacing_mlarge"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="@string/btn_dialog_cancel"
            style="@style/Widget.AppCompat.Button.Borderless"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>

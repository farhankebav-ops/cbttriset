<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@+id/inter_form_content_layout"
    android:background="#1c2933"
    android:paddingTop="100dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="20sp"
        android:textColor="#dae6f2"
        android:gravity="center_horizontal"
        android:id="@+id/inter_form_content_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"/>
    <TextView
        android:textSize="15.5sp"
        android:textColor="#8595a6"
        android:id="@+id/inter_form_content_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_below="@+id/inter_form_content_title"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"/>
    <View
        android:background="#3a4a59"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="36dp"
        android:layout_marginBottom="27.5dp"
        android:layout_below="@+id/inter_form_content_description"/>
</RelativeLayout>

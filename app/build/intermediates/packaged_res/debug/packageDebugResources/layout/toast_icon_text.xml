<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/parent_view"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/grey_90"
    app:cardCornerRadius="23dp"
    app:cardElevation="0dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/spacing_smlarge"
        android:paddingTop="@dimen/spacing_middle"
        android:paddingRight="@dimen/spacing_smlarge"
        android:paddingBottom="@dimen/spacing_middle"
        android:layout_width="match_parent"
        android:layout_height="45dp">
        <ImageView
            android:id="@+id/icon"
            android:layout_width="@dimen/spacing_mlarge"
            android:layout_height="@dimen/spacing_mlarge"
            app:srcCompat="@drawable/ic_close"
            app:tint="@android:color/white"/>
        <View
            android:layout_width="@dimen/spacing_middle"
            android:layout_height="0dp"/>
        <TextView
            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
            android:textColor="@color/grey_5"
            android:gravity="center"
            android:id="@+id/message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Error Toast"
            android:maxLines="1"
            android:singleLine="true"/>
        <View
            android:layout_width="@dimen/spacing_middle"
            android:layout_height="0dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <sg.bigo.ads.common.view.RoundedImageView
        android:id="@+id/inter_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="-68dp"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="20sp"
        android:textColor="#ff333333"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/inter_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/bigo_ad_title_default"
        android:maxLines="1"
        android:layout_below="@+id/inter_icon"
        android:layout_centerHorizontal="true"
        android:fontFamily="sans-serif-medium"/>
    <TextView
        android:textSize="13sp"
        android:textColor="#b3333333"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/inter_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/bigo_ad_description_default"
        android:maxLines="1"
        android:layout_below="@+id/inter_title"
        android:layout_centerHorizontal="true"/>
    <Button
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:ellipsize="end"
        android:id="@+id/inter_btn_cta"
        android:background="#ff009dff"
        android:paddingLeft="2dp"
        android:paddingRight="2dp"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:text="@string/bigo_ad_cta_default"
        android:maxLines="1"
        android:layout_below="@+id/inter_description"
        android:layout_centerHorizontal="true"
        android:textAllCaps="false"/>
</RelativeLayout>

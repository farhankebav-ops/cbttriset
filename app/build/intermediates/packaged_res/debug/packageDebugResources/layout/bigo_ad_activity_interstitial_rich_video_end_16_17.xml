<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/inter_layout_end_page"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/inter_end_page_image_layout"
        android:background="@drawable/bigo_ad_gradual_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/inter_end_page">
        <sg.bigo.ads.common.view.RoundedImageView
            android:layout_gravity="center"
            android:id="@+id/inter_end_page_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/inter_end_page"
        android:background="@android:color/white"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/word_icon_container">
        <sg.bigo.ads.common.view.RoundedImageView
            android:id="@+id/inter_icon"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="-40dp"/>
        <TextView
            android:textSize="20sp"
            android:textColor="#333333"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/inter_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/bigo_ad_title_default"
            android:maxLines="2"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>
        <TextView
            android:textSize="13sp"
            android:textColor="#888888"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/inter_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/bigo_ad_description_default"
            android:maxLines="2"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>
        <LinearLayout
            android:id="@+id/bigo_ad_btn_class"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp">
            <Button
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:ellipsize="end"
                android:id="@+id/inter_btn_cta_main"
                android:background="@drawable/bigo_ad_button_bg_rectangle_green"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="16dp"
                android:text="@string/bigo_ad_cta_default"
                android:maxLines="1"
                android:layout_weight="1"
                android:textAllCaps="false"/>
            <Button
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:ellipsize="end"
                android:id="@+id/inter_btn_cta"
                android:background="@drawable/bigo_ad_button_bg_rectangle_blue"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/bigo_ad_cta_default"
                android:maxLines="1"
                android:layout_weight="1"
                android:layout_toRightOf="@+id/inter_btn_cta_main"
                android:textAllCaps="false"
                android:layout_toEndOf="@+id/inter_btn_cta_main"/>
        </LinearLayout>
        <include
            android:id="@+id/inter_warning_layout"
            layout="@layout/bigo_ad_layout_interstitial_ad_warning_bottom"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/word_icon_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"/>
    <include layout="@layout/bigo_ad_layout_interstitial_ad_mark_top_left"/>
</RelativeLayout>

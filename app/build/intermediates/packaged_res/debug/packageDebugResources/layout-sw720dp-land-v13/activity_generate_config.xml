<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        android:background="@color/white"
        android:scrollbars="vertical"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollingCache="true"
        android:layout_above="@+id/rel_bawah">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/color_light_primary"
                android:paddingLeft="@dimen/spacing_mlarge"
                android:paddingRight="@dimen/spacing_mlarge"
                android:paddingBottom="@dimen/spacing_mlarge"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">
                    <ImageView
                        android:id="@+id/logo"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:layout_margin="@dimen/spacing_xsmall"
                        android:src="@drawable/icon"/>
                    <View
                        android:layout_width="@dimen/spacing_large"
                        android:layout_height="0dp"/>
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Title"
                            android:textSize="35sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:id="@+id/txt_nama_sekolah"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="30sp"
                            android:textColor="@color/white"
                            android:id="@+id/txt_nama_ujian"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="30sp"
                            android:textColor="@color/white"
                            android:id="@+id/txt_url_ujian"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
                <androidx.cardview.widget.CardView
                    android:id="@+id/cd_msg"
                    android:background="@android:color/white"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_large"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    app:cardCornerRadius="2dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_large"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="35sp"
                            android:textColor="@color/grey_80"
                            android:gravity="center"
                            android:id="@+id/txt_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
            <com.mimikridev.ads.ui.BannerAdView
                android:id="@+id/bannerAdView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:layout_marginEnd="50dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/native_ad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.AppCompat.Title"
                    android:textSize="40sp"
                    android:textColor="@color/grey_90"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/spacing_mlarge"
                    android:layout_marginTop="@dimen/spacing_middle"
                    android:layout_marginRight="@dimen/spacing_mlarge"
                    android:layout_marginBottom="@dimen/spacing_middle"
                    android:text="@string/txt_config"
                    app:fontFamily="sans-serif-medium"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="@dimen/spacing_medium"
                    android:paddingRight="@dimen/spacing_medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="10dp">
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/img_customua"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_check"/>
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="30sp"
                            android:textColor="@color/grey_80"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_config_title_useragent"
                            app:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                            android:textSize="30sp"
                            android:textColor="@color/blue_600"
                            android:id="@+id/txt_customua"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="@dimen/spacing_medium"
                    android:paddingRight="@dimen/spacing_medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="10dp">
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/img_timer"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_check"/>
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="30sp"
                            android:textColor="@color/grey_80"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_config_title_timer"
                            app:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                            android:textSize="30sp"
                            android:textColor="@color/blue_600"
                            android:id="@+id/txt_timer"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="@dimen/spacing_medium"
                    android:paddingRight="@dimen/spacing_medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="10dp">
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/img_tokenmasuk"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_check"/>
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="30sp"
                            android:textColor="@color/grey_80"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_config_title_tokenin"
                            app:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                            android:textSize="30sp"
                            android:textColor="@color/blue_600"
                            android:id="@+id/txt_token_masuk"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="@dimen/spacing_medium"
                    android:paddingRight="@dimen/spacing_medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="10dp">
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/img_tokenkeluar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_check"/>
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="30sp"
                            android:textColor="@color/grey_80"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_config_title_tokenout"
                            app:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                            android:textSize="30sp"
                            android:textColor="@color/blue_600"
                            android:id="@+id/txt_token_keluar"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="@dimen/spacing_medium"
                    android:paddingRight="@dimen/spacing_medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="10dp">
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/img_linkkeluar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_check"/>
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="30sp"
                            android:textColor="@color/grey_80"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_config_title_exitlink"
                            app:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                            android:textSize="30sp"
                            android:textColor="@color/blue_600"
                            android:id="@+id/txt_link_keluar"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="@dimen/spacing_medium"
                    android:paddingRight="@dimen/spacing_medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="10dp">
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/img_copypaste"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_check"/>
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textSize="30sp"
                        android:textColor="@color/grey_80"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_config_allowcopypaste"
                        app:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="@dimen/spacing_medium"
                    android:paddingRight="@dimen/spacing_medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="10dp">
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/img_screenshoot"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_check"/>
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textSize="30sp"
                        android:textColor="@color/grey_80"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_config_allowscreenshoot"
                        app:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="@dimen/spacing_medium"
                    android:paddingRight="@dimen/spacing_medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="10dp">
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/img_clearcache"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_check"/>
                    <View
                        android:layout_width="@dimen/spacing_mlarge"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textSize="30sp"
                        android:textColor="@color/grey_80"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_config_clearcache"
                        app:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <RelativeLayout
        android:gravity="center"
        android:id="@+id/rel_bawah"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.balysv.materialripple.MaterialRippleLayout
                android:id="@+id/btn_generate_config"
                android:background="@color/color_light_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/RippleStyleWhite">
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@color/color_light_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageButton
                            android:background="@android:color/transparent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:srcCompat="@drawable/ic_outline_settings_24"
                            app:tint="@color/white"/>
                        <TextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:textColorHint="@color/white"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:hint="@string/btn_config_generate"/>
                    </LinearLayout>
                </LinearLayout>
            </com.balysv.materialripple.MaterialRippleLayout>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
